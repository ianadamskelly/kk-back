PORT=8080
DATABASE_URL=postgres://postgres@localhost:5432/kuzakizazi?sslmode=disable
JWT_SECRET=change-this-to-a-long-random-string
SEED_ADMIN_EMAIL=admin@kuzakizazi.com
SEED_ADMIN_PASSWORD=admin123
UPLOAD_DIR=uploads
# Protected files (digital downloads, course resources, member library
# files, course-task attachments). Reads gated through /api/files/{token}.
# This directory must be outside UPLOAD_DIR; mount it separately in prod.
PROTECTED_UPLOAD_DIR=protected_uploads
CORS_ORIGIN=http://localhost:3000
# HttpOnly session cookie for customer auth. In production set the
# domain to the parent so the frontend + api subdomains share it
# (e.g. ".kuzakizazi.com"), and enable Secure once HTTPS is on.
COOKIE_DOMAIN=
COOKIE_SECURE=false
